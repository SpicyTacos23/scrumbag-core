{# templates/components/navbar.html.twig #}
<header class="navbar" data-controller="navbar" data-navbar-scrolled-class="navbar--scrolled">
    <div class="navbar__inner">

        {# Logo #}
        <a href="{{ path('app_homepage') }}" class="navbar__logo" aria-label="Vortex Fest — inicio">
            <span class="navbar__logo-text">VORTEX</span>
            <span class="navbar__logo-year">FEST '26</span>
        </a>

        {# Navegación principal #}
        <nav class="navbar__nav" aria-label="Navegación principal">
            <ul class="navbar__links">
                <li><a href="#bands" class="navbar__link" data-navbar-target="link">Bandas</a></li>
                <li><a href="#schedule" class="navbar__link" data-navbar-target="link">Horario</a></li>
                <li><a href="#info" class="navbar__link" data-navbar-target="link">Info</a></li>
                <li><a href="#news" class="navbar__link" data-navbar-target="link">Noticias</a></li>
                <li><a href="#location" class="navbar__link" data-navbar-target="link">Ubicación</a></li>
            </ul>
        </nav>

        {# CTA Tickets #}
        <a href="#tickets" class="navbar__cta">
            <span>TICKETS</span>
        </a>

        {# Hamburger mobile #}
        <button class="navbar__burger"
                data-navbar-target="burger"
                data-action="click->navbar#toggleMenu"
                aria-label="Abrir menú"
                aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    {# Menú mobile desplegable #}
    <div class="navbar__mobile-menu" data-navbar-target="mobileMenu" aria-hidden="true">
        <nav>
            <ul class="navbar__mobile-links">
                <li><a href="#bands"    data-action="click->navbar#closeMenu">Bandas</a></li>
                <li><a href="#schedule" data-action="click->navbar#closeMenu">Horario</a></li>
                <li><a href="#info"     data-action="click->navbar#closeMenu">Info</a></li>
                <li><a href="#news"     data-action="click->navbar#closeMenu">Noticias</a></li>
                <li><a href="#location" data-action="click->navbar#closeMenu">Ubicación</a></li>
                <li><a href="#tickets"  data-action="click->navbar#closeMenu" class="mobile-cta">TICKETS</a></li>
            </ul>
        </nav>
    </div>
</header>
