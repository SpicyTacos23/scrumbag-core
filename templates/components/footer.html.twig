{# templates/components/footer.html.twig #}
<footer class="footer">

    <div class="footer__noise" aria-hidden="true"></div>

    <div class="footer__top">
        <div class="footer__brand">
            <p class="footer__logo">SCRUMBAG<br>FEST</p>
            <p class="footer__tagline">Underground. Sin compromisos.<br>Desde 2011.</p>
        </div>

        <nav class="footer__nav" aria-label="Navegación del footer">
            <div class="footer__nav-group">
                <h3 class="footer__nav-title">Festival</h3>
                <ul>
                    <li><a href="#bands">Bandas</a></li>
                    <li><a href="#schedule">Horario</a></li>
                    <li><a href="#info">Información general</a></li>
                    <li><a href="#location">Cómo llegar</a></li>
                </ul>
            </div>
            <div class="footer__nav-group">
                <h3 class="footer__nav-title">Comunidad</h3>
                <ul>
                    <li><a href="#">Fanzine</a></li>
                    <li><a href="#">Archivo / Historial</a></li>
                    <li><a href="#">Merch &amp; Distro</a></li>
                    <li><a href="#">Galería fotográfica</a></li>
                </ul>
            </div>
            <div class="footer__nav-group">
                <h3 class="footer__nav-title">Contacto</h3>
                <ul>
                    <li><a href="mailto:info@vortexfest.xyz">info@scrumbagfest.xyz</a></li>
                    <li><a href="#">Prensa</a></li>
                    <li><a href="#">Booking</a></li>
                    <li><a href="#">Acreditaciones</a></li>
                </ul>
            </div>
        </nav>

        {# Newsletter #}
        <div class="footer__newsletter" data-controller="newsletter">
            <h3 class="footer__nav-title">LISTA NEGRA</h3>
            <p>Sé el primero en enterarte de los anuncios de bandas.</p>
            <form class="footer__newsletter-form"
                  data-action="submit->newsletter#subscribe"
                  novalidate>
                <input type="email"
                       placeholder="tu@correo.com"
                       data-newsletter-target="email"
                       required
                       autocomplete="email">
                <button type="submit">→</button>
            </form>
            <p class="footer__newsletter-feedback" data-newsletter-target="feedback" aria-live="polite"></p>
        </div>
    </div>

    <div class="footer__bottom">
        <p class="footer__legal">
            &copy; {{ "now"|date("Y") }} Scrumbag Fest ·
            <a href="#">Política de privacidad</a> ·
            <a href="#">Aviso legal</a>
        </p>
        <p class="footer__credits">Hecho con rabia y Symfony 7</p>
    </div>

</footer>
