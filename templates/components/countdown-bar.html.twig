{# templates/components/countdown-bar.html.twig #}
<div class="countdown-bar" data-controller="countdown" data-countdown-date-value="2026-09-10T18:30:00">
    <div class="countdown-bar__inner">
        <span class="countdown-bar__label">EMPIEZA EN</span>

        <div class="countdown-bar__timer">
            <span class="countdown-bar__unit">
                <strong data-countdown-target="days">--</strong>
                <small>días</small>
            </span>
            <span class="countdown-bar__sep">:</span>
            <span class="countdown-bar__unit">
                <strong data-countdown-target="hours">--</strong>
                <small>horas</small>
            </span>
            <span class="countdown-bar__sep">:</span>
            <span class="countdown-bar__unit">
                <strong data-countdown-target="minutes">--</strong>
                <small>min</small>
            </span>
            <span class="countdown-bar__sep">:</span>
            <span class="countdown-bar__unit">
                <strong data-countdown-target="seconds">--</strong>
                <small>seg</small>
            </span>
        </div>

        <span class="countdown-bar__date">17–19 JUL 2026 · ARENAS DE LA CALAVERA</span>
    </div>
</div>
