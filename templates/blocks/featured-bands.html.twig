{# templates/blocks/featured-bands.html.twig #}
<section class="featured-bands" id="bands" data-controller="featured-bands">
    <header class="featured-bands__header">
        <div class="featured-bands__label">{{ 'featured-bands.confirmed'|trans }}</div>
        <h2 class="featured-bands__title">{{ 'featured-bands.lineup'|trans|upper }} <span class="featured-bands__title-accent">{{ data.date.year }}</span></h2>
        <a href="{{ path('app_bands') }}" class="featured-bands__all-link">
            {{ 'featured-bands.see-all'|trans }} →
        </a>
    </header>

    {# Scrollable bands grid: 4 per row, fades to black at the bottom #}
    <div class="featured-bands__scroll-wrap">
        <div class="featured-bands__grid" data-featured-bands-target="grid">
            {% for key, band in data.bands.bands %}
                <article class="band-card"
                         data-controller="band-card"
                         data-action="mouseenter->band-card#reveal mouseleave->band-card#hide">
                    {# Image #}
                    <div class="band-card__img-wrap">
                        {% if band.image is defined and band.image %}
                            <img class="band-card__img"
                                 src="{{ asset('uploads/bands/' ~ band.image) }}"
                                 alt="{{ band.name }}"
                                 loading="lazy">
                        {% else %}
                            <img class="band-card__img"
                                 src="https://picsum.photos/seed/{{ band.seed ?? band.name|lower|replace({' ': ''}) }}/600/400"
                                 alt="{{ band.name }}"
                                 loading="lazy">
                        {% endif %}
                        <div class="band-card__img-overlay" aria-hidden="true"></div>
                    </div>

                    {# Country / genre overlay on the image #}
                    <div class="band-card__overlay-meta">
                        <span class="band-card__country">{{ band.country }}</span>
                        <span class="band-card__genre">{{ band.genres|join('/') }}</span>
                    </div>

                    {# Hover reveal: link #}
                    <div class="band-card__reveal" data-band-card-target="reveal" aria-hidden="true">
                        <a href="{{ path('app_band_detail', { slug: key }) }}" class="band-card__link">
                            {{ 'featured-bands.details'|trans|upper }}
                        </a>
                    </div>

                    {# Band name: full-width bottom bar with background for legibility #}
                    <div class="band-card__name-bar">
                        <h3 class="band-card__name">{{ band.name }}</h3>
                    </div>
                </article>
            {% endfor %}
        </div>

        {# Fade-to-black gradient at the bottom of the scroll area #}
        <div class="featured-bands__fade" aria-hidden="true"></div>
    </div>

    {# CTA see more #}
    <div class="featured-bands__footer">
        <a href="{{ path('app_bands') }}" class="featured-bands__cta">
            <span>{{ 'featured-bands.see-all'|trans }}</span>
            <span class="featured-bands__cta-count">{{ data.bands.bands|length }}+</span>
        </a>
    </div>
</section>
