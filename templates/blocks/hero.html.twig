{# templates/blocks/hero.html.twig #}
<section
	class="hero" id="hero" data-controller="hero" aria-label="Hero principal">

	{# Background image (video?) + overlay #}
	<div class="hero__bg" aria-hidden="true">
		<img class="hero__bg-img" {% set background_image = 'build/images/homepage_lineup_' ~ data.date.year ~ '.png' %} src="{{ asset(background_image) }}" {#src="https://picsum.photos/seed/metalpit/1600/900" #} alt="" fetchpriority="high">
		<div class="hero__bg-overlay"></div>
		{# Texture noise SVG #}
		<div class="hero__noise"></div>
	</div>

	{# Content #}
	<div class="hero__content">

        {# edition #}
		<div class="hero__eyebrow" data-hero-target="eyebrow">
			<span class="hero__edition">{{ data.event.edition }}</span>
			<span class="hero__separator" aria-hidden="true">///</span>
			<span class="hero__dates">{{ data.date.days ~ ' ' ~ data.date.month ~ ' ' ~ data.date.year }}</span>
		</div>

        {# name + year #}
		<h1 class="hero__title" data-hero-target="title">
			<span class="hero__title-line hero__title-line--1">SCRUMBAG</span>
			<span class="hero__title-line hero__title-line--2">FEST
				<span style="color: red;">{{ data.date.year }}</span>
			</span>
		</h1>

        {# location #}
		<p class="hero__subtitle" data-hero-target="subtitle">
			{{ data.event.genres }}<br>
			<em>{{ data.location.description }},
				{{ data.location.city }}
				({{ data.location.country|upper }})</em>
		</p>

        {# actions buy + see bands #}
		<div class="hero__actions" data-hero-target="actions">
            {# buy tickets #}
			<a href="#tickets" class="hero__btn hero__btn--primary">
				<span>{{ 'tickets.buy'|trans|upper }}</span>
				<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M5 12h14M12 5l7 7-7 7"/>
				</svg>
			</a>
            {# see all bands #}
			<a href="#bands" class="hero__btn hero__btn--ghost">{{ 'bands.all'|trans|upper }}</a>
		</div>

		{# Stats #}
		<div class="hero__stats" data-hero-target="stats">
			<div class="hero__stat">
				<strong>{{ data.bands.bands|length }}+</strong>
				<span>{{ 'stats.bands'|trans }}</span>
			</div>
			<div class="hero__stat">
				<strong>{{ data.date.total_days }}</strong>
				<span>{{ 'stats.days'|trans }}</span>
			</div>
			<div class="hero__stat">
				<strong>{{ data.bands.countries|length }}+</strong>
				<span>{{ 'stats.countries'|trans }}</span>
			</div>
		</div>

	</div>

	{# scroll down #}
	<a href="#bands-marquee" class="hero__scroll-arrow" aria-label="Ir al contenido">
		<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
			<path d="M12 5v14M5 12l7 7 7-7"/>
		</svg>
	</a>

</section>
