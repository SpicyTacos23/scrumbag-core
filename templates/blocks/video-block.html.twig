{# templates/blocks/video-block.html.twig #}
{#
    Optional parameter:
    - video_path: path to the local promo video (relative to the build/ dir)
#}
{% set video_src = video_path ?? asset('build/video/promo.mp4') %}

	<section class="video-block" data-controller="video_block"> <div class="video-block__content">
		<div class="video-block__meta">
			<span class="video-block__label">PROMO</span>
			<h2 class="video-block__title">
				Scrumbag Fest<br><span>{{ data.date.year }}</span>
			</h2>
			<p class="video-block__desc">
				Lorem ipsum dolor sit amet, consectetur adipiscing elit.
				                Tria dias de inferno sonoro en las montañas. Sin postureo.
				                Sin mainstream. Solo música de verdad.
			</p>
		</div>

		{# Thumbnail with play overlay #}
		<div class="video-block__thumb-wrap" data-action="click->video_block#openModal" data-video_block-video-src-param="{{ video_src }}" role="button" tabindex="0" aria-label="Reproducir promo">
			<img class="video-block__thumb" src="{{ asset('build/images/promo_thumbnail.png') }}" alt="Promo Scrumbag Fest 2025" loading="lazy" onerror="this.src='https://picsum.photos/seed/aftermovie/1280/720'">
			<div class="video-block__thumb-overlay" aria-hidden="true">
				<span class="video-block__big-play" aria-hidden="true">▶</span>
			</div>
		</div>
	</div>

	{# Video modal (managed by Stimulus) #}
	<div class="video-block__modal" data-video_block-target="modal" aria-modal="true" role="dialog" aria-label="Reproductor de video" aria-hidden="true" tabindex="-1">
		<div class="video-block__modal-backdrop" data-action="click->video_block#closeModal"></div>
		<div class="video-block__modal-inner">
			<button class="video-block__modal-close" data-action="click->video_block#closeModal" aria-label="Cerrar video">✕</button>
			<div class="video-block__iframe-wrap">
				<video data-video_block-target="video" controls playsinline preload="none">
					Tu navegador no soporta vídeo HTML5.
				</video>
			</div>
		</div>
	</div>
</section>
