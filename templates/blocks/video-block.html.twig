{# templates/blocks/video-block.html.twig #}
{#
    Optional parameter:
    - video_path: path to the local promo video (relative to the build/ dir)
#}

{# templates/blocks/video-block.html.twig #}

{% set videos = data.video %}
{% set video = videos[0] %}

{% set video_src = asset('build/video/' ~ video.src) %}
{% set video_thumb = asset('build/images/' ~ video.thumb) %}

<section class="video-block"
         data-controller="video_block"
         data-video_block-videos-value='{{ videos|json_encode }}'>

    <div class="video-block__content">

        <div class="video-block__meta">
            <span class="video-block__label">VIDEO</span>
            <h2 class="video-block__title">
                Scrumbag Fest<br><span data-video_block-target="year">{{ video.year }}</span>
            </h2>
            <p class="video-block__desc" data-video_block-target="description">
                {{ video.description }}
            </p>
        </div>

        <div class="video-block__thumb-wrap"
             data-action="click->video_block#openModal"
             data-video_block-index-param="0">

            <img class="video-block__thumb"
                 data-video_block-target="thumb"
                 src="{{ video_thumb }}"
                 alt="{{ video.title }}"
                 loading="lazy">

            <div class="video-block__thumb-overlay">
                <span class="video-block__big-play">▶</span>
            </div>

            {# Botón siguiente #}
            <button class="video-block__next"
                    data-action="click->video_block#nextVideo click->stopPropagation">
                ➜
            </button>
        </div>
    </div>

    {# Modal #}
    <div class="video-block__modal"
         data-video_block-target="modal"
         aria-hidden="true">

        <div class="video-block__modal-backdrop"
             data-action="click->video_block#closeModal"></div>

        <div class="video-block__modal-inner">
            <button class="video-block__modal-close"
                    data-action="click->video_block#closeModal">✕</button>

            <div class="video-block__iframe-wrap">
                <video data-video_block-target="video"
                       controls playsinline preload="none">
                    Tu navegador no soporta vídeo HTML5.
                </video>
            </div>
        </div>
    </div>
</section>

