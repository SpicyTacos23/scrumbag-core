{# templates/blocks/tickets-cta.html.twig #}
<section class="tickets-cta" id="tickets" data-controller="tickets-cta">

    <div class="tickets-cta__bg" aria-hidden="true">
        <img src="https://picsum.photos/seed/crowdmetal/1600/600" alt="" loading="lazy">
        <div class="tickets-cta__bg-overlay"></div>
    </div>

    <div class="tickets-cta__content">
        <h2 class="tickets-cta__title">
            ¿A QUÉ<br>ESPERAS?
        </h2>
        <p class="tickets-cta__sub">
            Abonos agotándose · Últimas unidades de camping disponibles
        </p>

        <div class="tickets-cta__tiers">
            <div class="tickets-cta__tier">
                <span class="tickets-cta__tier-name">ABONO 3 DÍAS</span>
                <span class="tickets-cta__tier-price">65 €</span>
                <span class="tickets-cta__tier-status tickets-cta__tier-status--available">DISPONIBLE</span>
            </div>
            <div class="tickets-cta__tier">
                <span class="tickets-cta__tier-name">ABONO + CAMPING</span>
                <span class="tickets-cta__tier-price">85 €</span>
                <span class="tickets-cta__tier-status tickets-cta__tier-status--low">ÚLTIMAS PLAZAS</span>
            </div>
            <div class="tickets-cta__tier">
                <span class="tickets-cta__tier-name">DÍA SUELTO</span>
                <span class="tickets-cta__tier-price">30 €</span>
                <span class="tickets-cta__tier-status tickets-cta__tier-status--available">DISPONIBLE</span>
            </div>
        </div>

        <a href="https://tickets.scrumbagfest.xyz"
           class="tickets-cta__btn"
           target="_blank"
           rel="noopener">
            COMPRAR AHORA
        </a>

        <p class="tickets-cta__note">
            Venta exclusiva online · Sin cargos de gestión · Pulseras nominales
        </p>
    </div>

</section>
