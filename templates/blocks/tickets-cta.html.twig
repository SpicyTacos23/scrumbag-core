{# templates/blocks/tickets-cta.html.twig #}
<section class="tickets-cta" id="tickets" data-controller="tickets-cta">

    <div class="tickets-cta__bg" aria-hidden="true">
        <img src="https://picsum.photos/seed/crowdmetal/1600/600" alt="" loading="lazy">
        <div class="tickets-cta__bg-overlay"></div>
    </div>

    <div class="tickets-cta__content">
        <h2 class="tickets-cta__title">
            {{ 'tickets.title'|trans|upper }}
        </h2>
        <p class="tickets-cta__sub">
            {{ 'tickets.sub-title'|trans|upper|raw }}
        </p>

        <div class="tickets-cta__tiers">
            <div class="tickets-cta__tier">
                <span class="tickets-cta__tier-name">{{ 'tickets.pass.full'|trans }}</span>
                <span class="tickets-cta__tier-price">{{ data.tickets.full.price }} £</span>
                <span class="tickets-cta__tier-name"><i>+{{ data.tickets.full.tax }} {{ 'tickets.tax'|trans }}</i></span>
                <span class="tickets-cta__tier-status tickets-cta__tier-status--available">{{ 'tickets.available'|trans }}</span>
            </div>
            <div class="tickets-cta__tier">
                <span class="tickets-cta__tier-name">{{ 'tickets.pass.thu'|trans }}</span>
                <span class="tickets-cta__tier-price">{{ data.tickets.thursday.price }} £</span>
                <span class="tickets-cta__tier-name"><i>+{{ data.tickets.thursday.tax }} {{ 'tickets.tax'|trans }}</i></span>
                <span class="tickets-cta__tier-status tickets-cta__tier-status--available">{{ 'tickets.available'|trans }}</span>
            </div>
            <div class="tickets-cta__tier">
                <span class="tickets-cta__tier-name">{{ 'fri'|trans }}</span>
                <span class="tickets-cta__tier-price">{{ data.tickets.friday.price }} £</span>
                <span class="tickets-cta__tier-name"><i>+{{ data.tickets.friday.tax }} {{ 'tickets.tax'|trans }}</i></span>
                <span class="tickets-cta__tier-status tickets-cta__tier-status--available">{{ 'tickets.available'|trans }}</span>
            </div>
            <div class="tickets-cta__tier">
                <span class="tickets-cta__tier-name">{{ 'tickets.pass.sat'|trans }}</span>
                <span class="tickets-cta__tier-price">{{ data.tickets.saturday.price }} £</span>
                <span class="tickets-cta__tier-name"><i>+{{ data.tickets.saturday.tax }} {{ 'tickets.tax'|trans }}</i></span>
                <span class="tickets-cta__tier-status tickets-cta__tier-status--low">{{ 'tickets.low'|trans }}</span>
            </div>
        </div>

        <a href="https://www.ticketsource.com/scrumbagfest"
           class="tickets-cta__btn"
           target="_blank"
           rel="noopener">
            {{ 'tickets.buy-now'|trans }}
        </a>

        <p class="tickets-cta__note">
            {{ 'tickets.note'|trans }}
        </p>
    </div>

</section>
