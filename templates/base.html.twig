<!DOCTYPE html>
<html lang="es" data-controller="theme">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}VORTEX FEST — Underground Metal Festival
			{% endblock %}
		</title>
		<meta
		name="description" content="{% block meta_description %}El festival de metal más underground de la península. Grindcore, Death, Black, Noise.{% endblock %}">

		{# Google Fonts - display + body #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
		href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Share+Tech+Mono&family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet">

		{# CSS global #}
		{{ encore_entry_link_tags('app') }}
		{{ encore_entry_link_tags('reset') }}
		{{ encore_entry_link_tags('base') }}
		{{ encore_entry_link_tags('navbar') }}
		{{ encore_entry_link_tags('floating-sidebar') }}
		{{ encore_entry_link_tags('footer') }}

		{# CSS de bloque específico de la página #}
		{% block stylesheets %}{% endblock %}

		{# Stimulus / importmap #}
		{{ encore_entry_script_tags('app') }}

	</head>
	<body
		data-controller="page-loader">

		{# ─── Barra superior de cuenta regresiva ─── #}
		{% include 'components/countdown-bar.html.twig' %}

		{# ─── Navbar ─── #}
		{% include 'components/navbar.html.twig' %}

		{# ─── Layout principal: sidebar + content ─── #}
		<div
			class="site-wrapper">

			{# Bloque flotante lateral izquierdo #}
			{% include 'components/floating-sidebar.html.twig' %}

			{# Contenido principal #}
			<main class="main-content" id="main-content"> {% block body %}{% endblock %}
				</main>

			</div>

			{# ─── Footer ─── #}
			{% include 'components/footer.html.twig' %}

			{% block javascripts %}{% endblock %}
		</body>
	</html>
